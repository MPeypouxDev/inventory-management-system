@startuml
title Diagramme de Cas d'Utilisation - Gestion de Stock

actor "Administrateur" as Admin

rectangle "Gestion de Stock" {

    package "Authentification" {
        usecase "Se connecter" as UC1
        usecase "Se déconnecter" as UC2
    }

    package "Produits" {
        usecase "Ajouter un produit" as UC3
        usecase "Modifier un produit" as UC4
        usecase "Supprimer un produit" as UC5
        usecase "Consulter les produits" as UC6
        usecase "Filtrer les produits" as UC7
        usecase "Exporter en Excel" as UC8
        usecase "Voir l'historique" as UC9
    }

    package "Mouvements" {
        usecase "Ajouter un mouvement" as UC10
        usecase "Consulter les mouvements" as UC11
        usecase "Filtrer les mouvements" as UC12
        usecase "Exporter en PDF" as UC13
    }

    package "Fournisseurs" {
        usecase "Gérer les fournisseurs" as UC14
    }

    package "Catégories" {
        usecase "Gérer les catégories" as UC15
    }

    package "Utilisateurs" {
        usecase "Gérer les utilisateurs" as UC16
        usecase "Voir l'historique utilisateur" as UC17
    }

    package "Dashboard" {
        usecase "Consulter le dashboard" as UC18
    }
}

