<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.stockmanager.controller.MovementController"
      spacing="15" style="-fx-background-color: #f5f6fa; -fx-padding: 25px;">

    <Label text="Gestion des Mouvements"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="+ Ajouter" onAction="#handleAdd"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8px 15px; -fx-cursor-: hand;"/>
        <TextField fx:id="searchField" promptText="Recherche un mouvement..."
                   style="-fx-padding: 8px; -fx-pref-width: 250px;"/>
        <Button text="Rechercher" onAction="#handleSearch"
                style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-padding: 8px 15px; -fx-cursor-: hand;"/>
        <Button text="Export PDF" onAction="#handleExportPdf"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8px 15px; -fx-cursor: hand;"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 0 0 10 0;"/>
        <ComboBox fx:id="typeFilter" promptText="Type"
                  onAction="#handleFilter" prefWidth="120"/>
        <ComboBox fx:id="productFilter" promptText="Produit"
                  onAction="#handleFilter" prefWidth="180"/>
        <DatePicker fx:id="startDateFilter" promptText="Date début"
                    onAction="#handleFilter" prefWidth="150"/>
        <DatePicker fx:id="endDateFilter" promptText="Date fin"
                    onAction="#handleFilter" prefWidth="150"/>
        <Button text="Réinitialiser" onAction="#handleResetFilters"
                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-padding: 8px 15px; -fx-cursor: hand;"/>
    <HBox/>

    <TableView fx:id="stockMovementTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
            <TableColumn fx:id="productColumn" text="Produit" prefWidth="200"/>
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="80"/>
            <TableColumn fx:id="quantityColumn" text="Quantité" prefWidth="50"/>
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="100"/>
            <TableColumn fx:id="reasonColumn" text="Raison" prefWidth="200"/>
            <TableColumn fx:id="userColumn" text="Utilisateur" prefWidth="120"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button fx:id="prevButton" text="◀ Précédent" onAction="#handlePreviousPage"
                style="-fx-padding: 8px 15px; -fx-cursor: hand;"/>
        <Label fx:id="pageLabel" text="Page 1"/>
        <Button fx:id="nextButton" text="Suivant ▶" onAction="#handleNextPage"
                style="-fx-padding: 8px 15px; -fx-cursor: hand;"/>
    </HBox>
</VBox>