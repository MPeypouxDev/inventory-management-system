<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.stockmanager.controller.MainController"
            prefWidth="1000" prefHeight="700">

    <!-- Barre du haut -->
    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 15px 20px;" spacing="10" alignment="CENTER_LEFT">
            <Label text="Gestion de Stock"
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Label fx:id="alertLabel"
                   style="-fx-text-fill: #e74c3c; -fx-font-weight: bold; -fx-font-size: 14px;"/>
        </HBox>
    </top>

    <!-- Menu gauche -->
    <left>
        <VBox style="-fx-background-color: #34495e; -fx-padding: 15px 10px;" spacing="3" prefWidth="200">
            <Button text="Accueil" onAction="#showDashboard"
                    prefWidth="180" style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 10px"/>
            <Button text="Produits" onAction="#showProducts"
                    prefWidth="180" style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 10px;"/>
            <Button text="Fournisseurs" onAction="#showSuppliers"
                    prefWidth="180" style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 10px;"/>
            <Button text="Mouvements" onAction="#showMovements"
                    prefWidth="180" style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 10px;"/>
            <Button text="Catégorie" onAction="#showCategories"
                    prefWidth="180" style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 10px;"/>
            <Button text="Utilisateurs" onAction="#showUsers"
                    prefWidth="180" style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 10px;"/>
            <Button text="Déconnexion" onAction="#handleLogout"
                    prefWidth="180" style="-fx-background-color: transparent; -fx-text-fill: #e74c3c; -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 10px;"/>
        </VBox>
    </left>

    <center>
        <VBox fx:id="contentArea" style="-fx-background-color: #f5f6fa; -fx-padding: 25px;">
        </VBox>
    </center>

</BorderPane>