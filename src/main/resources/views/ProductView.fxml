<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.stockmanager.controller.ProductController"
      spacing="15" style="-fx-background-color: #f5f6fa; -fx-padding: 25px;">

    <Label text="Gestion des Produits"
        style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="+ Ajouter" onAction="#handleAdd"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8px 15px; -fx-cursor-: hand;"/>
        <TextField fx:id="searchField" promptText="Rechercher un produit..."
                    style="-fx-padding: 8px; -fx-pref-width: 250px;"/>
        <Button text="Rechercher" onAction="#handleSearch"
                style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-padding: 8px 15px; -fx-cursor-: hand;"/>
        <Button text="Export Excel" onAction="#handleExportExcel"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8px 15px; -fx-cursor: hand;"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 0 0 10 0;">
        <ComboBox fx:id="categoryFilter" promptText="Catégorie"
                    onAction="#handleFilter" prefWidth="150"/>
        <ComboBox fx:id="statusFilter" promptText="Statut"
                    onAction="#handleFilter" prefWidth="120"/>
        <Button text="Réinitialiser" onAction="#handleResetFilters"
                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-padding: 8px 15px; -fx-cursor: hand;"/>
    </HBox>

    <TableView fx:id="productTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
            <TableColumn fx:id="nameColumn" text="Nom" prefWidth="200"/>
            <TableColumn fx:id="stockColumn" text="Stock" prefWidth="80"/>
            <TableColumn fx:id="priceColumn" text="Prix vente" prefWidth="100"/>
            <TableColumn fx:id="categoryColumn" text="Catégorie" prefWidth="150"/>
            <TableColumn fx:id="statusColumn" text="Statut" prefWidth="60"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button text="Modifier" onAction="#handleEdit"
                style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8px 15px; -fx-cursor: hand;"/>
        <Button text="Supprimer" onAction="#handleDelete"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8px 15px; -fx-cursor: hand;"/>
        <Button text="Historique" onAction="#handleHistory"
                style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8px 15px; -fx-cursor: hand;"/>

        <Button fx:id="prevButton" text="◀ Précédent" onAction="#handlePreviousPage"
                style="-fx-padding: 8px 15px; -fx-cursor: hand;"/>
        <Label fx:id="pageLabel" text="Page 1"/>
        <Button fx:id="nextButton" text="Suivant ▶" onAction="#handleNextPage"
                style="-fx-padding: 8px 15px; -fx-cursor: hand;"/>
    </HBox>

</VBox>